{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/generate-content",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/triple-whale-daily",
      "schedule": "0 22 * * *"
    }
  ]
}
